<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-name="deploy.DeployDashboard">
        <div class="o_deploy_dashboard">
            <div t-if="state.loading" class="d-flex align-items-center justify-content-center h-100 w-100">
                <i class="fa fa-spinner fa-spin fa-3x text-muted" />
            </div>
            <t t-elif="!state.agent">
                <div class="d-flex align-items-center justify-content-center h-100 w-100 text-muted">
                    <p>No agent selected. Open this dashboard from an agent form view.</p>
                </div>
            </t>
            <t t-else="">
                <div class="o_branches_view w-100 d-flex flex-column flex-lg-row">
                    <div class="o_sh_panel_left o_branches_left_panel bg-light border-end h-lg-100 flex-shrink-0">
                        <nav class="navbar navbar-expand-lg p-0" role="navigation">
                            <div class="navbar-header border-bottom d-lg-none w-100">
                                <button
                                    type="button"
                                    class="navbar-toggler py-2 d-flex justify-content-between btn btn-light btn-block w-100 rounded-0"
                                    t-on-click="toggleLeftPanel"
                                >
                                    <span class="small">All branches</span>
                                    <i t-attf-class="fa {{ state.leftPanelOpen ? 'fa-chevron-up' : 'fa-chevron-down' }}" />
                                </button>
                            </div>
                            <div t-att-class="'navbar-collapse w-100 d-lg-block ' + (state.leftPanelOpen ? 'd-block' : 'd-none')">
                                <EnvPanel
                                    envs="{prod: prodEnv, staging: stagingEnvs}"
                                    selected="state.selectedEnv"
                                    onSelect="(env) => selectEnv(env)"
                                    undeployedBranches="state.undeployedBranches"
                                    pendingProduction="pendingProduction"
                                    pendingStaging="pendingStaging"
                                    onDeployBranch="(branch, isProduction) => deployBranch(branch, isProduction)"
                                />
                            </div>
                        </nav>
                    </div>
                    <EnvContent
                        env="state.selectedEnv"
                        agent="state.agent"
                        tabs="tabs"
                        activeTab="state.activeTab"
                        heartbeat="state.heartbeat || undefined"
                        onSelectTab="(tab) => selectTab(tab)"
                        onUndeployBranch="(branch) => undeployBranch(branch)"
                    />
                </div>
            </t>
        </div>
    </t>
</templates>
