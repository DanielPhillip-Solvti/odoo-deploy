<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-name="deploy.EnvContent">
        <div class="o_deploy_env_content o_sh_panel_right h-lg-100 flex-grow-1 d-flex flex-column bg-white" style="min-width: 0;">
            <!-- Agent Header (always visible) -->
            <div class="o_env_header border-bottom px-3 py-2">
                <div class="d-flex justify-content-between align-items-center flex-wrap">
                    <div class="d-flex align-items-center gap-2">
                        <div>
                            <div class="fw-bold d-flex align-items-center" style="font-size: 1.2rem;">
                                <t t-esc="props.agent?.name" />
                                <span
                                    t-att-class="'d-inline-block rounded-circle ms-2 ' + (
                                        props.agent?.status === 'active' ? 'bg-success' :
                                        props.agent?.status === 'error' ? 'bg-danger' :
                                        'bg-secondary'
                                    )"
                                    style="width: 14px; height: 14px;"
                                    t-att-title="'Agent status: ' + (props.agent?.status || 'unknown') + (props.agent?.last_heartbeat ? ' | Last heartbeat: ' + props.agent?.last_heartbeat : '')"
                                    role="status"
                                />
                            </div>
                            <div t-if="props.env" class="text-muted" style="font-size: 0.95rem;">
                                <t t-esc="props.env.repository_branch" />
                            </div>
                        </div>
                    </div>
                    <GitCommandPanel t-if="props.env" env="props.env" agent="props.agent" />
                </div>
            </div>

            <!-- No Heartbeat Alert -->
            <div
                t-if="props.agent &amp;&amp; !props.agent.last_heartbeat"
                class="alert alert-warning m-3 mb-0 d-flex align-items-center gap-2"
                role="alert"
            >
                <i class="fa fa-exclamation-triangle" />
                <span>
                    Agent has not sent a heartbeat yet. Run the bootstrap script on your server to register it.
                    <button class="btn btn-sm btn-outline-warning ms-2" t-on-click="() => props.onSelectTab('settings')">
                        Go to Settings
                    </button>
                </span>
            </div>

            <!-- Tab Bar (always visible) -->
            <ul class="o_deploy_tabs nav nav-tabs flex-nowrap d-flex flex-shrink-0 border-bottom bg-light px-2" role="tablist">
                <li
                    t-foreach="props.tabs"
                    t-as="tab"
                    t-key="tab.id"
                    class="nav-item text-uppercase"
                    t-att-class="tab.id === props.activeTab ? 'active' : ''"
                >
                    <a
                        class="nav-link px-3 btn btn-sm d-flex align-items-center shadow-none border-0 rounded-0"
                        t-on-click.prevent="() => props.onSelectTab(tab.id)"
                    >
                        <i t-attf-class="fa {{tab.icon}} me-1 d-none d-md-inline" />
                        <t t-esc="tab.label" />
                    </a>
                </li>
                <li t-if="props.env" class="nav-item ms-auto">
                    <button
                        class="nav-link btn btn-sm d-flex align-items-center shadow-none border-0 rounded-0 text-danger"
                        t-on-click="undeploy"
                        title="Undeploy this branch"
                    >
                        <i class="fa fa-trash me-1" />
                        <span class="d-none d-md-inline">Undeploy</span>
                    </button>
                </li>
            </ul>

            <!-- Tab Content -->
            <div class="o_deploy_tab_content flex-grow-1 overflow-auto bg-100 p-3">
                <t t-if="props.activeTab === 'history'">
                    <HistoryTab t-if="props.env" env="props.env" agent="props.agent" />
                    <div t-else="" class="text-muted text-center py-5">
                        <i class="fa fa-history fa-3x mb-3" />
                        <p>Select an environment to view its commit history.</p>
                    </div>
                </t>
                <t t-elif="props.activeTab === 'logs'">
                    <LogsTab t-if="props.env" env="props.env" agent="props.agent" />
                    <div t-else="" class="text-muted text-center py-5">
                        <p>Select an environment to view its logs.</p>
                    </div>
                </t>
                <t t-elif="props.activeTab === 'shell'">
                    <ShellTab t-if="props.env" env="props.env" agent="props.agent" />
                    <div t-else="" class="text-muted text-center py-5">
                        <p>Select an environment to open a shell.</p>
                    </div>
                </t>
                <t t-elif="props.activeTab === 'monitor'">
                    <MonitorTab t-if="props.env" env="props.env" heartbeat="props.heartbeat" />
                    <div t-else="" class="text-muted text-center py-5">
                        <p>Select an environment to view monitoring data.</p>
                    </div>
                </t>
                <BackupsTab t-elif="props.activeTab === 'backups'" agent="props.agent" />
                <SettingsTab t-elif="props.activeTab === 'settings'" env="props.env" agent="props.agent" />
            </div>
        </div>
    </t>
</templates>
