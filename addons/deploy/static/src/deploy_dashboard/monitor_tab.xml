<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-name="deploy.MonitorTab">
        <div class="o_deploy_monitor_tab">
            <!-- Status Cards -->
            <div class="row g-3 mb-4">
                <div class="col-12 col-md-3">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-body text-center">
                            <div class="text-muted small text-uppercase fw-bold mb-1">Environment Status</div>
                            <h3
                                t-att-class="props.env.state === 'active' ? 'text-success' : props.env.state === 'error' ? 'text-danger' : 'text-warning'"
                            >
                                <i
                                    t-att-class="'fa ' + (props.env.state === 'active' ? 'fa-check-circle' : props.env.state === 'error' ? 'fa-exclamation-circle' : 'fa-clock-o')"
                                />
                                <span class="ms-1">
                                    <t t-esc="props.env.state" />
                                </span>
                            </h3>
                        </div>
                    </div>
                </div>

                <div class="col-12 col-md-3">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-body text-center">
                            <div class="text-muted small text-uppercase fw-bold mb-1">Branch</div>
                            <h5 class="mt-2">
                                <i class="fa fa-code-fork text-primary" />
                                <span class="ms-1">
                                    <t t-esc="props.env.repository_branch" />
                                </span>
                            </h5>
                        </div>
                    </div>
                </div>

                <div class="col-12 col-md-3">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-body text-center">
                            <div class="text-muted small text-uppercase fw-bold mb-1">Odoo Version</div>
                            <h5 class="mt-2">
                                <i class="fa fa-tag text-info" />
                                <span class="ms-1">
                                    <t t-esc="props.env.odoo_version" />
                                </span>
                            </h5>
                        </div>
                    </div>
                </div>

                <div class="col-12 col-md-3">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-body text-center">
                            <div class="text-muted small text-uppercase fw-bold mb-1">Production</div>
                            <h5 class="mt-2">
                                <t t-if="props.env.is_production">
                                    <i class="fa fa-check-circle text-success" />
                                    <span class="ms-1 text-success">Yes</span>
                                </t>
                                <t t-else="">
                                    <i class="fa fa-times-circle text-muted" />
                                    <span class="ms-1 text-muted">No</span>
                                </t>
                            </h5>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Heartbeat Info -->
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white border-bottom d-flex align-items-center">
                    <i class="fa fa-heartbeat text-danger me-2" />
                    <strong>Agent Heartbeat</strong>
                    <t t-if="props.heartbeat">
                        <span class="ms-auto text-muted small">
                            <i class="fa fa-clock-o me-1" />
                            <t t-esc="props.heartbeat.last_heartbeat || 'N/A'" />
                        </span>
                    </t>
                </div>
                <div class="card-body">
                    <t t-if="!props.heartbeat">
                        <div class="d-flex align-items-center gap-2 text-muted py-3">
                            <i class="fa fa-spinner fa-spin" />
                            <span>Waiting for heartbeat data…</span>
                        </div>
                    </t>
                    <t t-else="">
                        <pre class="mb-0 bg-light p-3 rounded" style="max-height: 400px; overflow: auto;">
                            <t t-esc="heartbeatJSON" />
                        </pre>
                    </t>
                </div>
            </div>
        </div>
    </t>
</templates>
