<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-name="deploy.BackupsTab">
        <div class="o_backups_tab">
            <t t-if="backups.length === 0">
                <div class="text-muted text-center py-5">
                    <i class="fa fa-database fa-3x mb-3" />
                    <p>No backups available. Run a backup with dump to create one.</p>
                </div>
            </t>
            <t t-else="">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <span class="text-muted small">
                        <t t-esc="backups.length" />
                        backup(s) available
                    </span>
                    <button
                        class="btn btn-sm btn-primary"
                        t-att-disabled="!state.selected || state.downloading"
                        t-on-click="downloadSelected"
                    >
                        <i t-att-class="'fa ' + (state.downloading ? 'fa-spinner fa-spin' : 'fa-download') + ' me-1'" />
                        <t t-if="state.downloading">Downloading...</t>
                        <t t-else="">Download Selected</t>
                    </button>
                </div>
                <div class="list-group">
                    <div
                        t-foreach="backups"
                        t-as="filename"
                        t-key="filename"
                        t-att-class="'list-group-item list-group-item-action d-flex align-items-center ' + (state.selected === filename ? 'active' : '')"
                        t-on-click="() => selectBackup(filename)"
                        role="button"
                    >
                        <i class="fa fa-file-archive-o me-2" />
                        <t t-esc="filename" />
                        <i t-if="state.selected === filename" class="fa fa-check ms-auto" />
                    </div>
                </div>
            </t>
        </div>
    </t>
</templates>
