<odoo>
    <record id="deploy_agent_form_view" model="ir.ui.view">
        <field name="name">deploy.agent.form</field>
        <field name="model">deploy.agent</field>
        <field name="arch" type="xml">
            <form string="Client Project Dashboard" class="o_deploy_agent_form">
                <header>
                    <field name="status" widget="statusbar" statusbar_visible="offline,pending,active,error" />
                </header>

                <sheet>
                    <!-- Form Title Block using standard utility structures -->
                    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
                        <div class="oe_title">
                            <label for="name" string="Client Project" class="text-uppercase small fw-bold text-muted" />
                            <h1 class="m-0">
                                <field name="name" placeholder="e.g. client-prod-01" required="1" />
                            </h1>
                        </div>
                        <div class="text-end">
                            <span
                                class="badge rounded-pill p-2 px-3 align-middle fs-6"
                                decoration-success="status == 'active'"
                                decoration-warning="status == 'pending'"
                                decoration-danger="status == 'error'"
                            >
                                <i class="fa fa-circle me-1 small" title="Status" />
                                <field name="status" class="fw-bold text-uppercase" />
                            </span>
                        </div>
                    </div>

                    <!-- Summary Info Cards utilizing responsive Bootstrap and standard backgrounds -->
                    <div class="row g-3 mb-4">
                        <div class="col-12 col-md-4">
                            <div class="card shadow-sm border p-3 bg-view">
                                <div class="text-muted small text-uppercase fw-bold">
                                    <i class="fa fa-git me-1" />
                                    Connected Repository
                                </div>
                                <div class="fs-6 fw-semibold mt-1 text-truncate text-muted">
                                    <field name="repository_url" readonly="1" />
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Main Tabbed Interface Configuration -->
                    <notebook>
                        <!-- Tab 1: Server Branches -->
                        <page string="Branches &amp; Builds" name="branches_tab" icon="fa-code-branch">
                            <div class="p-2">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <h5 class="m-0 fw-semibold text-muted">Active Server Branch Environments</h5>
                                </div>
                                <field name="staging_environment_ids" mode="list">
                                    <list string="Active Branches" edit="false" create="true">
                                        <field name="repository_branch" decoration-bf="1" />
                                        <field name="odoo_version" widget="badge" decoration-info="1" />
                                        <field name="is_production" widget="boolean_toggle" string="Production" />
                                        <field
                                            name="state"
                                            widget="badge"
                                            decoration-success="state == 'active'"
                                            decoration-warning="state == 'deploying'"
                                            decoration-danger="state == 'error'"
                                        />
                                    </list>
                                </field>
                            </div>
                        </page>

                        <!-- Tab 2: Backup Snapshot Controls -->
                        <page string="Backups Manager" name="backups_tab" icon="fa-database">
                            <div class="p-3">
                                <div class="alert alert-warning mb-4 d-flex align-items-center gap-3" role="alert">
                                    <i class="fa fa-exclamation-triangle fa-2x" title="Warning" />
                                    <div>
                                        <h6 class="alert-heading m-0 fw-bold">Manual Snapshot &amp; Rollback Controls</h6>
                                        <p class="m-0 small">
                                            Create system template states or drop secure database neutralized copies safely from this
                                            control board.
                                        </p>
                                    </div>
                                </div>

                                <div class="row g-3 mb-3">
                                    <div class="col-12 col-md-3">
                                        <button
                                            name="backup_no_dump"
                                            type="object"
                                            string="Backup (Template Only)"
                                            class="btn btn-secondary w-100 p-4 h-100 d-flex flex-column align-items-center justify-content-center text-center gap-2 border shadow-sm deploy-action-card"
                                        >
                                            <i class="fa fa-file-code-o fa-2x text-info" />
                                            <span class="fw-bold">Template Backup</span>
                                            <span class="text-muted small">Snap configuration parameters only</span>
                                        </button>
                                    </div>
                                    <div class="col-12 col-md-3">
                                        <button
                                            name="backup_with_dump"
                                            type="object"
                                            string="Backup (With Dump)"
                                            class="btn btn-secondary w-100 p-4 h-100 d-flex flex-column align-items-center justify-content-center text-center gap-2 border shadow-sm deploy-action-card"
                                        >
                                            <i class="fa fa-database fa-2x text-primary" />
                                            <span class="fw-bold">Database Dump</span>
                                            <span class="text-muted small">Full active transactional state backup</span>
                                        </button>
                                    </div>
                                    <div class="col-12 col-md-3">
                                        <button
                                            name="download_production_dump"
                                            type="object"
                                            string="Backup (Production)"
                                            class="btn btn-secondary w-100 p-4 h-100 d-flex flex-column align-items-center justify-content-center text-center gap-2 border shadow-sm deploy-action-card"
                                        >
                                            <i class="fa fa-server fa-2x text-success" />
                                            <span class="fw-bold">Production Copy</span>
                                            <span class="text-muted small">Optimized clone for replication</span>
                                        </button>
                                    </div>
                                    <div class="col-12 col-md-3">
                                        <button
                                            name="download_neutralised_dump"
                                            type="object"
                                            string="Backup (Neutralised)"
                                            class="btn btn-secondary w-100 p-4 h-100 d-flex flex-column align-items-center justify-content-center text-center gap-2 border shadow-sm deploy-action-card"
                                        >
                                            <i class="fa fa-shield fa-2x text-warning" />
                                            <span class="fw-bold">Neutralized Dump</span>
                                            <span class="text-muted small">Data scrambled for testing environments</span>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </page>

                        <!-- Tab 3: System Setup CLI Command -->
                        <page string="Setup &amp; CLI" name="bootstrap_tab" icon="fa-terminal">
                            <div class="p-3">
                                <div class="text-muted small text-uppercase fw-bold mb-2">CLI Bootstrap Instructions</div>
                                <div class="alert alert-info mb-3" role="alert">
                                    Run this complete setup script directly inside your server's console terminal to connect and
                                    register this agent automatically.
                                </div>
                                <div class="p-3 border rounded bg-view">
                                    <field nolabel="1" name="bootstrap_script" widget="CopyClipboardText" readonly="1" />
                                </div>

                                <div class="mt-4">
                                    <group string="Authentication Key">
                                        <label for="api_key" string="Authentication Key" class="text-muted small fw-bold mb-1" />
                                        <div class="o_row gap-2">
                                            <field name="api_key" widget="CopyClipboardChar" />
                                            <button name="generate_api_key" type="object" string="Regenerate" icon="fa-refresh" />
                                        </div>
                                    </group>
                                </div>
                            </div>
                        </page>

                        <!-- Tab 4: Parameters Settings -->
                        <page string="Settings" name="settings_tab" icon="fa-gears">
                            <div class="p-3">
                                <h5 class="fw-semibold mb-4">Network Credentials &amp; Key Settings</h5>
                                <group>
                                    <group string="Specifications Settings">
                                        <field name="repository_url" widget="CopyClipboardChar" string="Target Repository URL" />
                                    </group>
                                </group>
                            </div>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
