<odoo>
    <record id="deploy_agent_tree_view" model="ir.ui.view">
        <field name="name">deploy.agent.tree</field>
        <field name="model">deploy.agent</field>
        <field name="arch" type="xml">
            <list string="Agents" action="deploy.action_deploy_dashboard" type="action">
                <field name="name" />
                <field name="repository_url" />
                <field name="status" widget="badge" />
                <field name="last_heartbeat" />
            </list>
        </field>
    </record>

    <record id="deploy_agent_form_view" model="ir.ui.view">
        <field name="name">deploy.agent.form</field>
        <field name="model">deploy.agent</field>
        <field name="arch" type="xml">
            <form js_class="deploy.agent.dashboard">
                <group>
                    <field name="name" />
                </group>
            </form>
        </field>
    </record>
</odoo>
