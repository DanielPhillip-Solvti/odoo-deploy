<odoo>
    <record id="action_deploy_dashboard" model="ir.actions.client">
        <field name="name">Agent Dashboard</field>
        <field name="tag">deploy.dashboard</field>
    </record>

    <record model="ir.actions.act_window" id="action_deploy_agents">
        <field name="name">Agents</field>
        <field name="res_model">deploy.agent</field>
        <field name="view_mode">list,form</field>
    </record>

    <record model="ir.actions.act_window" id="action_github_app_config">
        <field name="name">GitHub App Configuration</field>
        <field name="res_model">github.app.config</field>
        <field name="view_mode">form</field>
        <field name="res_id" ref="deploy.github_app_config_record" />
    </record>

    <record model="ir.actions.act_window" id="action_deploy_events">
        <field name="name">Events</field>
        <field name="res_model">deploy.event</field>
        <field name="view_mode">tree</field>
    </record>

    <menuitem id="deploy_menu_root" name="Deploy" web_icon="deploy,static/description/icon.svg" sequence="10" />
    <menuitem id="deploy_menu_dashboard" name="Dashboard" parent="deploy_menu_root" action="action_deploy_dashboard" sequence="5" />
    <menuitem id="deploy_menu_agents" name="Agents" parent="deploy_menu_root" action="action_deploy_agents" sequence="10" />
    <menuitem
        id="deploy_menu_github_config"
        name="GitHub Configuration"
        parent="deploy_menu_root"
        action="action_github_app_config"
        sequence="30"
    />
    <menuitem id="deploy_menu_events" name="Events" parent="deploy_menu_root" action="action_deploy_events" sequence="40" />
</odoo>
