<odoo>
    <!-- list view -->
    <record id="deploy_environment_tree_view" model="ir.ui.view">
        <field name="name">deploy.environment.tree</field>
        <field name="model">deploy.environment</field>
        <field name="arch" type="xml">
            <list>
                <field name="repository_branch"/>
                <field name="odoo_version"/>
                <field name="is_production"/>
            </list>
        </field>
    </record>

    <record id="deploy_environment_form_view" model="ir.ui.view">
        <field name="name">deploy.environment.form</field>
        <field name="model">deploy.environment</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="url"/>
                        <field name="repository_url"/>
                        <field name="repository_branch"/>
                        <field name="odoo_version"/>
                        <field name="is_production"/>
                    </group>
                    <notebook>
                        <page string="Commands">
                            <div class="d-flex flex-row gap-2">
                                <button name="reset_repository" type="object" string="Reset Repository" class="btn-primary"/>
                                <button name="restart_odoo" type="object" string="Restart Odoo" class="btn-primary"/>
                                <button name="restore_backup" type="object" string="Restore Backup" class="btn-primary"/>
                                <button name="undeploy" type="object" string="Remove Environment" class="btn-primary"/>
                                <button name="deploy" type="object" string="Deploy Environment" class="btn-primary"/>
                            </div>
                        </page>
                        <page string="Logs">
                            <p>Logs content goes here.</p>
                        </page>
                        <page string="History">
                            <widget name="github_commit_history"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
</odoo>