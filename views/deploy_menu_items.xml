<odoo>
    <record model="ir.actions.act_window" id="action_deploy_environments">
        <field name="name">Environments</field>
        <field name="res_model">deploy.environment</field>
        <field name="view_mode">list,form</field>
    </record>

    <record model="ir.actions.act_window" id="action_deploy_vms">
        <field name="name">Virtual Machines</field>
        <field name="res_model">deploy.vm</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="deploy_menu_root" name="Deploy" sequence="10"/>
    <menuitem id="deploy_menu_vms" name="Virtual Machines" parent="deploy_menu_root" action="action_deploy_vms" sequence="10"/>
    <menuitem id="deploy_menu_environments" name="Environments" parent="deploy_menu_root" action="action_deploy_environments" sequence="20"/>
</odoo>