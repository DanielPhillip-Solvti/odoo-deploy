# Global configuration block
{
    email admin@example.com
}

# Backup and log WebSocket - path-based route works with any hostname
:80 {
    @agent_ws path /backup-ws* /logs-ws* /shell-ws*
    handle @agent_ws {
        @missing_token {
            not query token=*
        }
        respond @missing_token "Missing token" 401

        reverse_proxy {env.AGENT_WS_ADDR}:9876 {
            header_up X-Backup-Token {query.token}
            transport http {
                read_timeout 5m
                write_timeout 5m
            }
        }
    }
    handle {
        respond "Infrastructure initialized. Deploy environments via Odoo to map domains." 200
    }
}
